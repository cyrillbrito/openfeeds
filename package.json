{
  "name": "openfeeds",
  "version": "0.9.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev --filter=@repo/web --filter=@repo/worker",
    "build": "turbo build",
    "lint": "oxlint",
    "check-types": "turbo check-types",
    "checks": "turbo run check-types lint",
    "generate:auth-schema": "turbo -F @repo/db generate:auth-schema",
    "migrate": "bun --cwd=apps/migrator migrate",
    "create-user": "bun --cwd=packages/scripts create-user",
    "test-ui": "bun --cwd=apps/e2e test-ui",
    "test-update-snapshots": "bun --cwd=apps/e2e test-update-snapshots",
    "clean-install": "find . -name \"node_modules\" -type d -exec rm -rf {} + && rm bun.lock && bun install",
    "test": "echo '123'"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "turbo": "^2.8.21"
  },
  "packageManager": "bun@1.3.11"
}
