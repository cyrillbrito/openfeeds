{
  "name": "openfeeds",
  "version": "0.15.2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@repo/web --filter=@repo/server --filter=@repo/worker",
    "build": "turbo run build",
    "lint": "oxlint",
    "format:check": "oxfmt --check .",
    "format": "oxfmt --write .",
    "checks": "turbo run //#lint && bun run format:check",
    "generate:auth-schema": "turbo -F @repo/db generate:auth-schema",
    "create-user": "bun --cwd=packages/scripts create-user",
    "test-ui": "bun --cwd=apps/e2e test-ui",
    "test-update-snapshots": "bun --cwd=apps/e2e test-update-snapshots",
    "clean-install": "find . -name \"node_modules\" -type d -exec rm -rf {} + && rm bun.lock && bun install"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "remark-breaks": "^4.0.0",
    "turbo": "^2.9.14",
    "typescript": "^6"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": []
}
