{
  "name": "openfeeds",
  "version": "0.11.8",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=@repo/web --filter=@repo/worker",
    "build": "turbo run build",
    "lint": "oxlint",
    "format:check": "oxfmt --check .",
    "format": "oxfmt --write .",
    "checks": "turbo run //#lint && pnpm run format:check",
    "generate:auth-schema": "turbo -F @repo/db generate:auth-schema",
    "migrate": "pnpm --filter @repo/migrator run migrate",
    "create-user": "pnpm --filter @repo/scripts run create-user",
    "test-ui": "pnpm --filter @repo/e2e run test-ui",
    "test-update-snapshots": "pnpm --filter @repo/e2e run test-update-snapshots",
    "clean-install": "find . -name \"node_modules\" -type d -exec rm -rf {} + && rm pnpm-lock.yaml && pnpm install"
  },
  "devDependencies": {
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.21"
  },
  "engines": {
    "node": "^24"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild",
      "msgpackr-extract",
      "protobufjs",
      "sharp",
      "spawn-sync",
      "workerd"
    ]
  }
}
