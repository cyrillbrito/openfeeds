{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "trailingComma": "all",
  "singleQuote": true,
  "printWidth": 100,
  "sortTailwindcss": {},
  "sortImports": { "newlinesBetween": false },
  "ignorePatterns": [
    "**/build",
    "**/public",
    "pnpm-lock.yaml",
    "routeTree.gen.ts",
    "packages/db/drizzle/",
    "*.md",
    "apps/worker/src/benchmark/fixtures/**"
  ]
}
